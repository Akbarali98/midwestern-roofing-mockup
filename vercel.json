    { "src": "/blog/after-the-storm-a-homeowners-guide-to-roof-damage-and-insurance-claims", "dest": "/blog-after-storm.html" },
    { "src": "/blog/boost-your-curb-appeal-and-home-value-the-power-of-siding-and-gutters", "dest": "/blog-siding-gutters.html" },
    { "src": "/blog/your-guide-to-preventing-ice-dams-and-snow-load-damage-this-winter", "dest": "/blog-ice-dams.html" },
